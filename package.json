{
  "name": "linkedin-clay-sync",
  "version": "1.0.0",
  "description": "Sync your LinkedIn connections into Clay (or any webhook) with auto-enrichment — no LinkedIn API required",
  "type": "module",
  "bin": {
    "linkedin-clay-sync": "./src/cli.ts"
  },
  "scripts": {
    "sync": "npx tsx src/cli.ts sync",
    "enrich": "npx tsx src/cli.ts enrich",
