# ── Required ──────────────────────────────────────────────────────────────────
# Your Clay webhook URL for the LinkedIn Connections table.
# Get it from Clay: Table → Sources → + Add Source → Webhook → Copy URL
CLAY_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/your-token-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Hunter.io API key for email enrichment (free tier = 25 lookups/month)
# Get at: hunter.io/api-key
HUNTER_API_KEY=

# Force Playwright browser instead of native Chrome (non-macOS users: leave blank)
# FORCE_PLAYWRIGHT=true
