    "dev": "npx tsx src/cli.ts"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
