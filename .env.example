# Clay webhook URL for your LinkedIn Connections table
CLAY_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/your-token-here

# Optional: Hunter.io API key for email enrichment (free tier = 25/mo)
# Get at: hunter.io/api-key
HUNTER_API_KEY=

# Optional: Path to your LinkedIn Connections.csv
# Default: auto-detects from ~/Downloads
LINKEDIN_CSV_PATH=
